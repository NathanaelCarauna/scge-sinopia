OUVIDOR --> UC21
OUVIDOR --> UC23

GESTOR --> UC8
GESTOR --> UC9
GESTOR --> UC10
GESTOR --> UC11
GESTOR --> UC17

ADMIN --> UC16
ADMIN --> UC17
ADMIN --> UC18
ADMIN --> UC19
ADMIN --> UC20
ADMIN --> UC24

COLABORADOR --> UC8
COLABORADOR --> UC9

IA --> UC1
IA --> UC2
IA --> UC3
IA --> UC4
IA --> UC5
IA --> UC6
IA --> UC11
IA --> UC12
IA --> UC22
IA --> UC24

