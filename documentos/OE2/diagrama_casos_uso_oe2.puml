@startuml diagrama_casos_uso_oe2
!theme bluegray
title SINÓPIA OE2 - OUVIDOR.PE\nSistema de Suporte Inteligente ao Ouvidor

' Definindo atores
actor "Ouvidor" as OUVIDOR #LightBlue
actor "Gestor" as GESTOR #LightGreen
actor "Administrador" as ADMIN #Orange
actor "Colaborador" as COLABORADOR #LightYellow
actor "Sistema IA" as IA #LightPink

' Objetivos de Negócio
note top : **OBJETIVOS DE NEGÓCIO**\n• Desenvolver Sistema de Suporte Inteligente\n• Implementar IA Generativa para Análise Automática\n• Personalizar Encaminhamentos\n• Garantir Acessibilidade e Conformidade\n• Assegurar Performance e Escalabilidade

package "OUVIDOR.PE - Sistema de Suporte Inteligente" {
  
  package "Processamento com IA" #LightCyan {
    usecase "Classificar Manifestação\nAutomaticamente" as UC1
    usecase "Processar com IA/PLN" as UC2
    usecase "Analisar Sentimentos\ne Emoções" as UC3
    usecase "Detectar Duplicatas\ne Similaridade" as UC4
    usecase "Sugerir Encaminhamentos\nInteligentes" as UC5
    usecase "Minerar Base de\nConhecimento" as UC6
  }
  
  package "Gestão e Monitoramento" #LightSalmon {
    usecase "Monitorar Prazos\ne Alertas" as UC7
    usecase "Gerar Dashboard\nInterativo" as UC8
    usecase "Criar Relatórios\nGerenciais" as UC9
    usecase "Analisar Performance\nOperacional" as UC10
    usecase "Gerenciar Alertas\nPreditivos" as UC11
  }
  
  package "Automação e Respostas" #LightGoldenRodYellow {
    usecase "Gerar Respostas\nAutomáticas" as UC12
    usecase "Gerenciar Templates\ne Textos Padrão" as UC13
    usecase "Enviar Notificações\nMulticanal" as UC14
    usecase "Executar Encaminhamento\nAutomático" as UC15
  }
  
  package "Administração e Segurança" #Lavender {
    usecase "Gerenciar Perfis\ne Acessos" as UC16
    usecase "Auditar Ações\ne Decisões IA" as UC17
    usecase "Configurar Sistema\ne Regras" as UC18
    usecase "Integrar Sistemas\nExternos" as UC19
    usecase "Garantir Conformidade\nLGPD" as UC20
  }
  
  package "Curadoria e Qualidade" #MistyRose {
    usecase "Gerenciar Palavras-Chave\ne Taxonomia" as UC21
    usecase "Executar Limpeza\nPeriódica" as UC22
    usecase "Validar Qualidade\ndas Classificações" as UC23
    usecase "Treinar e Calibrar\nModelos IA" as UC24
  }
}

